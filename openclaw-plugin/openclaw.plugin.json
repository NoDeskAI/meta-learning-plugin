{
  "id": "meta-learning",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspaceRoot": {
        "type": "string",
        "description": "Path to meta-learning workspace root (defaults to OpenClaw workspace)"
      },
      "signalBufferDir": {
        "type": "string",
        "description": "Directory for signal buffer files (relative to workspaceRoot)"
      },
      "taxonomyPath": {
        "type": "string",
        "description": "Path to error_taxonomy.yaml (relative to workspaceRoot)"
      },
      "pythonBin": {
        "type": "string",
        "description": "Path to python binary for running Layer 2/3"
      },
      "enabled": {
        "type": "boolean",
        "description": "Enable/disable the plugin"
      }
    }
  },
  "uiHints": {
    "workspaceRoot": {
      "label": "Workspace Root",
      "placeholder": "~/.openclaw/workspace",
      "advanced": true
    },
    "pythonBin": {
      "label": "Python Binary",
      "placeholder": "~/.openclaw/workspace/venv/bin/python3",
      "advanced": true
    },
    "enabled": {
      "label": "Enable Meta-Learning",
      "help": "Toggle the meta-learning signal capture and quick think hooks"
    }
  },
  "skills": ["./skills"]
}
